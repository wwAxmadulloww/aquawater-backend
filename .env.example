# ── Server ────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# Required. The app refuses to start without it.
MONGODB_URI=mongodb://localhost:27017/aquawater

# Required in production. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string

# Comma-separated list of allowed browser origins.
# Leave empty to reflect any origin (development only).
CORS_ORIGINS=http://localhost:5173,https://aquawater-uz.vercel.app

# ── Telegram Bot ──────────────────────────────────────────────────────────
# From @BotFather. Without this the bot is disabled entirely.
TELEGRAM_BOT_TOKEN=
# Group/channel that receives new-order cards. Send /start to the bot in that
# chat and it replies with the id (groups start with -100...).
TELEGRAM_ADMIN_CHAT_ID=
# Public site URL used in the bot's inline buttons.
WEBAPP_URL=https://aquawater-uz.vercel.app

# Set to 'true' on serverless hosts (Vercel), where long-polling cannot run.
# Then register: https://api.telegram.org/bot<TOKEN>/setWebhook
#                ?url=https://<host>/api/telegram/webhook&secret_token=<secret>
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_SECRET=

# Set to 'false' to process queued updates from before the server started.
TELEGRAM_SKIP_BACKLOG=true

# ── Eskiz SMS (OTP delivery) ──────────────────────────────────────────────
# Leave blank to mock SMS — the code is printed to the server log instead.
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# ── OTP ───────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=5
OTP_RESEND_COOLDOWN=60
OTP_LENGTH=6

# Require SMS verification before /register succeeds. The current web UI has no
# OTP step, so enabling this without updating the frontend blocks all sign-ups.
REQUIRE_PHONE_VERIFICATION=false

# Accept the universal code 123456 in local development only.
ALLOW_DEV_OTP=false

# ── Google Sheets mirror (optional) ───────────────────────────────────────
# Leave blank to skip syncing. Share both sheets with the service account email.
GOOGLE_SHEET_ID=
GOOGLE_PRODUCTS_SHEET_ID=
GOOGLE_ORDERS_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── Seed script ───────────────────────────────────────────────────────────
# `npm run seed` wipes users and products. Must be 'true' to run.
ALLOW_DESTRUCTIVE_SEED=false
